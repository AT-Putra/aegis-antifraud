# Caddy reverse proxy + TLS otomatis (TRD §2, ADR-006).
# Dev: CADDY_DOMAIN tak di-set → http://localhost (tanpa TLS).
# Produksi: set CADDY_DOMAIN=domain.anda + CADDY_EMAIL → TLS otomatis.

{$CADDY_DOMAIN:http://localhost} {
	# Health check scoring API
	handle /health {
		reverse_proxy api:8000
	}

	# API scoring/callback/admin/analytics (kontrak 03 §/v1).
	# Anti-spoof (T-20): timpa X-Forwarded-For dgn peer TCP nyata ({remote_host}),
	# buang nilai apa pun yang dikirim klien → rate-limit/login-throttle per-IP tak bisa di-bypass.
	handle /v1/* {
		reverse_proxy api:8000 {
			header_up X-Forwarded-For {remote_host}
		}
	}

	# /dashboard (tanpa slash) → /dashboard/ (T-27): handle_path di bawah hanya cocokkan
	# path eksak /dashboard/* — tanpa redirect ini, refresh/akses /dashboard jatuh ke
	# catch-all prelanding & memunculkan "Tautan tidak valid".
	redir /dashboard /dashboard/ 301

	# Dashboard SPA (T-16) di /dashboard/* (base=/dashboard/, SPA fallback).
	handle_path /dashboard/* {
		root * /srv/dashboard
		try_files {path} /index.html
		file_server
	}

	# Pre-landing statis (T-10) — bundel default self-host. Host eksternal pakai bundel sama.
	handle {
		root * /srv/prelanding
		try_files {path} /index.html
		file_server
	}

	encode gzip
}
