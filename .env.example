# =====================================================================
# Aegis Anti Fraud — template environment. Salin ke `.env` lalu isi.
# `.env` TIDAK di-commit (lihat .gitignore). Jangan taruh rahasia di sini.
# =====================================================================

APP_ENV=development

# --- PostgreSQL (OLTP) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aegis
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aegis

# --- ClickHouse (OLAP) ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=aegis
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_DB=aegis

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Keamanan (WAJIB diisi nilai acak kuat di produksi) ---
SESSION_SIGNING_KEY=change-me-random-32+
JWT_SECRET=change-me-random-32+
SECRET_ENC_KEY=change-me-base64-32byte    # master key AES-256-GCM utk hmac_secret (TQ-08)

# --- Lokal & origin ---
TZ_DEFAULT=Asia/Jakarta
ALLOWED_ORIGINS=http://localhost

# --- Caddy / TLS ---
# Dev: http://localhost (tanpa TLS). JANGAN dikosongkan — Caddy butuh alamat valid.
# Produksi: CADDY_DOMAIN=fraud.contoh.com  &  CADDY_EMAIL=ops@contoh.com (TLS otomatis)
CADDY_DOMAIN=http://localhost
CADDY_EMAIL=

# =====================================================================
# Batas memori PARAMETRIK (mem_limit). Default di bawah = PROFIL DEV (≈8 GB host).
# ---------------------------------------------------------------------
# Profil DEV (mesin development spek rendah):
POSTGRES_MEM_LIMIT=1g
CLICKHOUSE_MEM_LIMIT=2g
REDIS_MEM_LIMIT=512m
REDIS_MAXMEMORY=384mb
API_MEM_LIMIT=1500m
CADDY_MEM_LIMIT=256m
#
# Profil PRODUKSI (TRD §7, host ≥12 GB) — pakai nilai ini di .env produksi:
#   POSTGRES_MEM_LIMIT=2g
#   CLICKHOUSE_MEM_LIMIT=4g
#   REDIS_MEM_LIMIT=512m
#   REDIS_MAXMEMORY=448mb
#   API_MEM_LIMIT=2g
#   CADDY_MEM_LIMIT=300m
# (ClickHouse otomatis pakai 70% dari mem_limit-nya — infra/clickhouse/config.d/memory.xml)
# =====================================================================
